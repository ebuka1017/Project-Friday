{
  "name": "friday",
  "version": "0.2.6",
  "description": "Friday — Autonomous Voice-Native AI Knowledge Worker for Windows",
  "main": "electron/main.js",
  "scripts": {
    "dev": "electron .",
    "build:sidecar": "dotnet publish sidecar/Sidecar.csproj -c Release -r win-x64 --self-contained true -p:PublishSingleFile=true",
    "postinstall": "npm run build:sidecar",
    "build": "npm run build:sidecar && electron-builder",
    "test:pipe": "node electron/test-pipe.js"
  },
  "author": "Isaac Okwuzi <isaacokwuzi@gmail.com> (https://x.com/nothiro__)",
  "license": "MIT",
  "build": {
    "compression": "store",
    "appId": "com.projectfriday.app",
    "productName": "Friday",
    "copyright": "Copyright © 2026 Isaac Okwuzi",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "extraResources": [
      {
        "from": "sidecar/bin/Release/net9.0-windows/win-x64/publish/",
        "to": "sidecar/",
        "filter": [
          "Sidecar.exe",
          "*.dll",
          "*.json"
        ]
      },
      {
        "from": "extension/",
        "to": "extension/"
      },
      ".env"
    ],
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "shared/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "protocols": [
      {
        "name": "Project Friday",
        "schemes": [
          "friday"
        ]
      }
    ]
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "@clerk/clerk-js": "^6.0.0",
    "@dotlottie/player-component": "^2.7.12",
    "@getzep/zep-cloud": "^3.18.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "electron-store": "^11.0.2",
    "sqlite3": "^5.1.7",
    "systeminformation": "^5.31.3",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  }
}
